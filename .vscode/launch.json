{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Fresh Folder)",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "fresh-workspace",
      "args": [
        "/tmp/opencode-dev-test",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--user-data-dir=/tmp/opencode-dev-userdata",
        "--disable-extensions"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "sourceMaps": true
    },
    {
      "name": "Run Extension (opencode monorepo)",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "npm: build",
      "args": [
        "${workspaceFolder}/..",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "sourceMaps": true
    }
  ]
}
